HOST=0.0.0.0
PORT=8080
WEBHOOK_SECRET=change-me-webhook-secret
WEBSOCKET_SECRET=change-me-websocket-secret
TOKEN_HEADER=X-Gitlab-Token
GITLAB_GROUP_PATH=example-group

# Management API (required)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-admin-password
JWT_SECRET=change-me-jwt-secret-at-least-16-chars
SOUNDS_DIR=/data/sounds
# Optional management tuning
# JWT_TTL_MINUTES=60
# SOUNDS_DIR=./data/sounds
# MAX_SOUND_UPLOAD_BYTES=10485760
# LOG_BROADCAST_CAP=2000
